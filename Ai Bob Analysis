<nav class="bg-[#0b1326] flex flex-col h-full py-8 border-r border-slate-800/20 w-64 shrink-0">
<div class="px-6 mb-10">
<h2 class="text-[#adc6ff] font-black font-manrope text-xl tracking-tight">The Curator</h2>
<p class="text-slate-500 text-[10px] uppercase tracking-widest font-bold">System Framework</p>
</div>
<div class="flex-1 space-y-1">
<a class="flex items-center gap-3 px-6 py-3 text-slate-500 hover:text-white hover:bg-[#2d3449] transition-all font-manrope font-medium text-xs" href="#">
<span class="material-symbols-outlined">dashboard</span>
                Workspace
            </a>
<a class="flex items-center gap-3 px-6 py-3 text-slate-500 hover:text-white hover:bg-[#2d3449] transition-all font-manrope font-medium text-xs" href="#">
<span class="material-symbols-outlined">database</span>
                Data Vault
            </a>
<a class="flex items-center gap-3 px-6 py-3 text-slate-500 hover:text-white hover:bg-[#2d3449] transition-all font-manrope font-medium text-xs" href="#">
<span class="material-symbols-outlined">schema</span>
                Protocols
            </a>
<a class="flex items-center gap-3 px-6 py-3 text-[#adc6ff] bg-[#171f33] rounded-r-full font-bold translate-x-1 duration-200 font-manrope text-xs" href="#">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">hub</span>
                Agent Hub
            </a>
</div>
<div class="px-6 mb-8">
<button class="intelligence-gradient text-on-primary-fixed w-full py-3 rounded-lg font-bold text-xs flex items-center justify-center gap-2">
<span class="material-symbols-outlined text-sm">add</span>
