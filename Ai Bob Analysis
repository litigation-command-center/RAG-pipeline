                    </div>
</div>
<!-- Agent Output Shell (Placeholder) -->
<div class="flex gap-4">
<div class="w-8 h-8 rounded-lg bg-surface-container-highest flex items-center justify-center shrink-0 border border-outline-variant/20">
<span class="material-symbols-outlined text-primary text-sm">smart_toy</span>
</div>
<div class="flex-1 space-y-4">
<div class="text-xs font-bold text-primary uppercase tracking-widest">Agent Protocol Stream</div>
<div class="glass-panel p-6 rounded-xl border border-outline-variant/10 min-h-[120px] flex flex-col justify-center items-center text-center">
<span class="material-symbols-outlined text-3xl text-surface-container-highest mb-2">pending_actions</span>
