<body class="bg-surface text-on-surface font-body overflow-hidden">
<!-- TopAppBar -->
<header class="bg-[#0b1326] flex justify-between items-center w-full px-6 h-16 docked full-width top-0 z-50">
<div class="flex items-center gap-8">
<span class="text-lg font-bold text-[#adc6ff] tracking-tighter font-manrope uppercase">Intelligence Protocol</span>
<div class="hidden md:flex items-center bg-[#171f33] px-4 py-2 rounded-full w-96">
<span class="material-symbols-outlined text-slate-400 text-sm">search</span>
<input class="bg-transparent border-none text-xs focus:ring-0 text-slate-200 w-full ml-2" placeholder="Search operational registry..." type="text"/>
</div>
</div>
<div class="flex items-center gap-4">
<button class="text-slate-400 hover:bg-[#2d3449] p-2 rounded-full transition-colors">
<span class="material-symbols-outlined">notifications</span>
</button>
<button class="text-slate-400 hover:bg-[#2d3449] p-2 rounded-full transition-colors">
<span class="material-symbols-outlined">settings</span>
</button>
<div class="h-8 w-8 rounded-full bg-surface-container-highest flex items-center justify-center">
<span class="material-symbols-outlined text-sm text-primary">account_circle</span>
</div>
</div>
</header>
<div class="flex h-[calc(100vh-64px)] overflow-hidden">
