<p class="text-[10px] text-slate-500 italic">Awaiting source files...</p>
</div>
</div>
<div class="p-3 bg-surface-container-highest/50 rounded-lg flex gap-3 items-start border border-outline-variant/5">
<span class="material-symbols-outlined text-slate-500 text-sm mt-0.5">account_tree</span>
<div>
<div class="text-xs font-bold text-on-surface">Semantic Mapping</div>
<p class="text-[10px] text-slate-500 italic">Inert</p>
</div>
</div>
</div>
<div class="space-y-3 pt-4 border-t border-outline-variant/10">
