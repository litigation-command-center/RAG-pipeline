                    </div>
<div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-surface-container-highest text-[10px] font-medium text-on-surface-variant border border-outline-variant/10">
<span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span>
                        Joy (Data Extraction)
                    </div>
</div>
</div>
<!-- Interaction Stream -->
<div class="flex-1 overflow-y-auto p-8 space-y-8">
<!-- System Status Message -->
<div class="flex justify-center">
<div class="bg-surface-container-highest/30 border border-outline-variant/10 px-4 py-2 rounded-full text-[10px] text-on-surface-variant font-mono uppercase tracking-widest">
